# pm convention: pnpm + Turbopack for Next.js projects.
#
# `engine-strict=true` enforces the engines field in package.json so
# stale Node versions are caught at install time. `auto-install-peers`
# matches Next.js 14+'s expectation that peers (React, react-dom) be
# installed automatically.

engine-strict=true
auto-install-peers=true
strict-peer-dependencies=false
