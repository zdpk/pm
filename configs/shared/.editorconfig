root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{rs,ts,tsx,js,jsx,py,dart,c,h}]
indent_style = space
indent_size = 2

[*.rs]
indent_size = 4

[*.py]
indent_size = 4

[*.{yaml,yml,toml,json}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
